putchar :: extern "putchar" proc(c: int32) -> int32;

main :: proc() -> int32 {
    shades := " .-:;+=xX$& ";

    for ypixel := 0; ypixel < 24; ypixel += 1 {
        y := cast(float32) ypixel / 12.0 - 1.0;

        for xpixel := 0; xpixel < 80; xpixel += 1 {
            x := cast(float32) xpixel / 30.0 - 2.0;

            x0 := x;
            y0 := y;
            iter := 0;

            for iter < 11 && x0 * x0 + y0 * y0 <= 4.0 {
                x1 := x0 * x0 - y0 * y0 + x;
                y1 := 2.0 * x0 * y0 + y;
                x0 = x1;
                y0 = y1;
                iter += 1;
            }

            putchar(cast(int32) shades[iter]);
        }
        putchar(10);
    }

    return 0;
}
