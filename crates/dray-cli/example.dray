Shape :: enum {
    Circle(int32),
    Rectangle(int32, int32),
    Unit,
}

measure :: proc(s: Shape) -> int32 {
    switch s {
    case Shape.Circle(r):
        return r * r * 3;
    case Shape.Rectangle(w, h):
        return w * h;
    case Shape.Unit:
        return 0;
    }
}

main :: proc() -> int32 {
    return measure(Shape.Circle(4))         // 48
         + measure(Shape.Rectangle(3, 5))   // 15
         + measure(Shape.Unit);             // 0
    // 63 in total
}
