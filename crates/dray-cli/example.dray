P :: struct {
    a: int32,
    b: int32,
}

Box :: struct(comptime T: type) {
    value: T,
}

main :: proc() -> int32 {
    static_assert(sizeof(int32) == 4, "int32 must be 4 bytes");
    static_assert(sizeof(P) == 8, "P must be two int32s");

    static_assert(sizeof(Box(int32)) == 4, "Box(int32) wraps one int32");

    total := sizeof(int32) + sizeof(P) + sizeof(Box(int32));
    return cast(int32) total;   // 4 + 8 + 4 = 16
}
