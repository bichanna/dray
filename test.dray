is_prime :: proc(n: int32) -> int32 {
    if n < 2 {
        return 0;
    }
    for d := 2; d * d <= n; d += 1 {
        if n % d == 0 {
            return 0;
        }
    }
    return 1;
}

main :: proc() -> int32 {
    count := 0;
    for i := 2; i < 10000000; i += 1 {
        if is_prime(i) == 1 {
            count += 1;
        }
    }
    return count;
}
